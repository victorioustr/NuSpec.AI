<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <IsPackable>true</IsPackable>
    <NoBuild>true</NoBuild>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
    <ContentTargetFolders>contentFiles</ContentTargetFolders>

    <!-- Package metadata -->
    <PackageId>NuSpec.AI</PackageId>
    <Version>3.1.1</Version>
    <Description>Automatically generates ai/package-map.json during dotnet pack, providing AI coding assistants with structured metadata about your package's public API surface. Supports JSON, YAML, and compact output formats plus opt-in attributes ([AiRole], [AiIgnore], [AiDescription]).</Description>
    <Authors>Sean Cooper</Authors>
    <PackageTags>AI;NuGet;documentation;metadata;Roslyn</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <DevelopmentDependency>true</DevelopmentDependency>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <!-- NU5128: empty lib/<tfm>/_._ placeholders are intentional (build-only package). -->
    <NoWarn>$(NoWarn);NU5128</NoWarn>
  </PropertyGroup>

  <!-- NuGet readme -->
  <ItemGroup>
    <None Include="..\..\NUGET_README.md" PackagePath="README.md" Pack="true" />
  </ItemGroup>

  <!-- Include build assets (props/targets) -->
  <ItemGroup>
    <None Include="build\**" PackagePath="build\" Pack="true" />
  </ItemGroup>

  <!-- Include the published CLI tool (populated by build.sh / dotnet publish) -->
  <ItemGroup>
    <None Include="tools\net8.0\**" PackagePath="tools\net8.0\" Pack="true" />
  </ItemGroup>

  <!-- Declare supported consumer target frameworks for the nuget.org Frameworks tab.
       NuSpec.AI ships no runtime assets (build-only); _._ is the NuGet convention
       for "this TFM is supported but contributes nothing to the consumer's bin". -->
  <ItemGroup>
    <None Include="_._" Pack="true" PackagePath="lib\netstandard2.0\" />
    <None Include="_._" Pack="true" PackagePath="lib\net6.0\" />
    <None Include="_._" Pack="true" PackagePath="lib\net8.0\" />
    <None Include="_._" Pack="true" PackagePath="lib\net9.0\" />
  </ItemGroup>

  <!-- Attribute source files compiled into consumer assemblies -->
  <ItemGroup>
    <Content Include="contentFiles\cs\any\NuSpec.AI\*.cs" Pack="true" PackagePath="contentFiles\cs\any\NuSpec.AI\" BuildAction="Compile" />
  </ItemGroup>

</Project>
