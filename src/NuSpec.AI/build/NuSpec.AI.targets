<Project>
  <PropertyGroup>
    <_NuSpecAiToolPath>$(MSBuildThisFileDirectory)..\tools\net8.0\NuSpec.AI.Tool.dll</_NuSpecAiToolPath>
    <_NuSpecAiOutputDir>$([MSBuild]::NormalizeDirectory('$(MSBuildProjectDirectory)', '$(IntermediateOutputPath)', 'nuspec-ai'))</_NuSpecAiOutputDir>
    <!-- Strip trailing slash so the quoted path doesn't become '\"' in shell invocation (Windows quirk) -->
    <_NuSpecAiOutputDirForCli>$(_NuSpecAiOutputDir.TrimEnd('\').TrimEnd('/'))</_NuSpecAiOutputDirForCli>
  </PropertyGroup>

  <!-- Register our target as a content provider for NuGet pack -->
  <PropertyGroup Condition="'$(NuSpecAiEnabled)' == 'true' and '$(IsPackable)' != 'false'">
    <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);NuSpecAiIncludePackageMaps</TargetsForTfmSpecificContentInPackage>
  </PropertyGroup>

  <!-- Generate all requested format files before pack -->
  <Target Name="NuSpecAiGeneratePackageMaps"
          BeforeTargets="NuSpecAiIncludePackageMaps"
          Condition="'$(NuSpecAiEnabled)' == 'true' and '$(IsPackable)' != 'false'">

    <MakeDir Directories="$(_NuSpecAiOutputDir)" />

    <PropertyGroup>
      <_NuSpecAiFullDocsArg Condition="'$(NuSpecAiIncludeFullDocs)' == 'true'"> --full-docs</_NuSpecAiFullDocsArg>
    </PropertyGroup>

    <Exec Command="dotnet &quot;$(_NuSpecAiToolPath)&quot; &quot;$(MSBuildProjectFullPath)&quot; --output &quot;$(_NuSpecAiOutputDirForCli)&quot; --formats &quot;$(NuSpecAiFormats)&quot;$(_NuSpecAiFullDocsArg)"
          ConsoleToMSBuild="true" />
  </Target>

  <!-- Add each generated file to the .nupkg under ai/ -->
  <Target Name="NuSpecAiIncludePackageMaps">
    <ItemGroup>
      <_NuSpecAiGeneratedFiles Include="$(_NuSpecAiOutputDir)*" />
    </ItemGroup>

    <ItemGroup>
      <TfmSpecificPackageFile Include="@(_NuSpecAiGeneratedFiles)">
        <PackagePath>ai/%(Filename)%(Extension)</PackagePath>
      </TfmSpecificPackageFile>
    </ItemGroup>
  </Target>
</Project>
